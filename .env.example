# Databricks — service principal (recommended)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_CLIENT_ID=your-service-principal-client-id
DATABRICKS_CLIENT_SECRET=your-service-principal-client-secret
# OR personal access token:
# DATABRICKS_TOKEN=dapi...

DATABRICKS_SQL_WAREHOUSE_ID=your-warehouse-id

# LLM — Anthropic is default (more reliable tool calling)
ANTHROPIC_API_KEY=your-anthropic-api-key
# MODEL_PROVIDER=anthropic   # or: ollama
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OLLAMA_MODEL=llama3.2

# Langfuse observability (optional — tracing is skipped if not set)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Agent → MCP server URL (set automatically in docker compose)
# MCP_SERVER_URL=http://localhost:8001/mcp
